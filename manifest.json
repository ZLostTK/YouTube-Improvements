{
  "manifest_version": 3,
  "name": "YouTube Improvements – Layout & Video Enhancer",
  "version": "1.1.5",
  "description": "Mejora YouTube: diseño optimizado de la página de video, control de velocidad, captura de pantalla, tema oscuro/claro, marcado de anuncios, bucle de video y descarga - todo activable/desactivable desde el popup de la extensión.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "YouTube Improvements",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/main-world/loader.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/main-world/*"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
